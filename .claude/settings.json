{
	"permissions": {
		"deny": [
			"Bash(cat .env*)",
			"Bash(cat secrets/*)",
			"Read(.env)",
			"Read(.env.*)",
			"Read(secrets/*)",
			"Edit(.env)",
			"Edit(.env.*)",
			"Edit(secrets/*)"
		],
		"allow": [
			"Bash(npm *)",
			"Bash(npx *)",
			"Bash(git status*)",
			"Bash(git log*)",
			"Bash(git diff*)",
			"Bash(git add *)",
			"Bash(git commit *)",
			"Bash(git branch*)",
			"Bash(git checkout*)",
			"Bash(git switch*)",
			"Bash(node *)",
			"Bash(ls *)",
			"Bash(mkdir *)",
			"Bash(chmod *)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/validate.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/post-edit-format.sh"
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/session-start.sh"
					}
				]
			}
		]
	}
}
